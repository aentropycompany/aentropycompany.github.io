---
/**
 * Landing page
 * Minimal corporate page: statement, projects, contacts, social links.
 * Tokens used: width-prose, layout-*, fg-primary, fg-secondary, fg-tertiary, separator
 */
import Page from '@layouts/Page.astro';
import SunLight from 'phosphor-astro/SunLight.astro';
import MoonLight from 'phosphor-astro/MoonLight.astro';
import XLogoFill from 'phosphor-astro/XLogoFill.astro';
import GithubLogoFill from 'phosphor-astro/GithubLogoFill.astro';
const year = new Date().getFullYear();
---

<Page title="The Aentropy Company" description="The less you think, the clearer it becomes">
  <main class="flow max-w-(--width-prose) min-h-screen mx-auto px-layout-sm flex flex-col items-stretch justify-center">

    <h1 class="text-display font-bold tracking-tighter">The Aentropy Company</h1>
    <p>
      We build with one intention: to reduce entropy. While the world drifts toward noise and disorder, we bring chaos
      back into clear structure.
    </p>

    <p>
      <a href="mailto:hello@theaentropy.company">hello@theaentropy.company</a>
    </p>

    <div class="pt-3 mt-layout-sm border-t border-separator flex flex-row items-center justify-between">
      <span class="text-fg-tertiary text-footnote font-medium">&copy; {year} The Aentropy Company</span>
      <div class="flex flex-row items-center gap-1">
        <button id="theme-toggle" class="btn-icon btn-icon-secondary" aria-label="Toggle theme">
          <SunLight class="theme-icon-sun icon-sm" style="display: none;" />
          <MoonLight class="theme-icon-moon icon-sm" />
        </button>
        <a href="https://x.com/aentropycompany" rel="noreferrer" target="_blank" class="btn-icon btn-icon-secondary no-underline hover:no-underline" aria-label="X">
          <XLogoFill class="icon-sm" />
        </a>
        <a href="https://github.com/aentropycompany" rel="noreferrer" target="_blank" class="btn-icon btn-icon-secondary no-underline hover:no-underline" aria-label="GitHub">
          <GithubLogoFill class="icon-sm" />
        </a>
      </div>
    </div>

  </main>

  <script>
    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.theme-icon-sun').forEach(el => {
        (el as HTMLElement).style.display = isDark ? 'block' : 'none';
      });
      document.querySelectorAll('.theme-icon-moon').forEach(el => {
        (el as HTMLElement).style.display = isDark ? 'none' : 'block';
      });
    }

    updateIcons();

    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const html = document.documentElement;
      html.classList.toggle('dark');
      const isDark = html.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcons();
    });
  </script>
</Page>
